# NVIDIA NIM Configuration
# Get your API key from https://catalog.ngc.nvidia.com/orgs/nvidia/teams/cloudai
#
# After editing, restart fc-server or save via fc-admin web UI (/admin).

# NVIDIA NIM base URL (OpenAI-compatible endpoint)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Your NVIDIA NGC API key
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here

# Model ID (must match the model you want to use)
# Examples: minimaxai/minimax-m2.7, meta/llama-3.2-3b-instruct, etc.
NVIDIA_NIM_MODEL=stepfun-ai/step-3.5-flash