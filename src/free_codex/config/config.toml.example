#:schema https://developers.openai.com/codex/config-schema.json
#
# Free Codex — NVIDIA NIM via local proxy (fc-server).
#
# The model name below should match NVIDIA_NIM_MODEL in your .env file.
# Run 'fc-init' to set this up automatically.
# Use 'fc-admin' to configure NVIDIA credentials and model via web UI.
#
# NVIDIA credentials live in ~/.config/free-codex/.env (see fc-init / env.example).

# Model ID - must match NVIDIA_NIM_MODEL in ~/.config/free-codex/.env
model = "minimaxai/minimax-m2.7"

# Provider alias (registered below)
model_provider = "free_codex_nim"

[model_providers.free_codex_nim]
name = "Free Codex (local NIM proxy)"
base_url = "http://127.0.0.1:8080/v1"
# Use OpenAI's Responses API (POST /v1/responses) — the preferred unified
# surface for agentic tool calling. Free Codex translates Responses ↔ Chat
# Completions internally so it still works with NIM / Ollama / vLLM upstream.
# `wire_api = "chat"` is no longer supported by Codex.
wire_api = "responses"

[windows]
sandbox = "elevated"